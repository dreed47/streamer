# Copy this file to .env and edit as needed

# Port the app listens on (host port when bridge mode, uvicorn port when host mode)
# Set a unique APP_PORT per folder if you want to run multiple instances
APP_PORT=5705

# Timezone for log timestamps (default: UTC)
# Use a tz database name: America/New_York, America/Chicago, America/Los_Angeles, Europe/London, etc.
# TZ=America/New_York

# Log verbosity (default: INFO)
# INFO  — normal operation: startup, stream start/end
# DEBUG — everything: per-request timing, stream reconnect details
# WARNING — only problems and errors
# LOG_LEVEL=INFO

# Docker container name (default: streamer1)
# Change this when running multiple instances to avoid name conflicts.
CONTAINER_NAME=streamer1

POLL_INTERVAL=30                 # seconds between model live-status checks
MAX_CONCURRENT=3                 # max simultaneous browser/recording sessions

# ── SMB / NAS mount (REQUIRED) ────────────────────────────────────────────────
# Recordings are written to an SMB share mounted at /recordings inside the container.
# The app will not start if the mount fails.
#
# SMB_PATH format: //HOST_IP/share/path/to/recordings  (forward slashes)
SMB_PATH=//192.168.1.100/share/recordings
SMB_USERNAME=your_smb_user
SMB_PASSWORD=your_smb_password

# ── Transcoding (optional) ────────────────────────────────────────────────────
# Re-encodes recordings after capture to reduce file size.
# Requires ffmpeg (included in the Docker image).
# TRANSCODE_ENABLED=false
# TRANSCODE_CODEC=h264          # h264 (universal) or h265 (smaller, needs codec support on playback device)
# TRANSCODE_CRF=23              # quality: h264: 18-28 (lower = better), h265: 24-32
# TRANSCODE_PRESET=fast         # speed vs compression: ultrafast / veryfast / faster / fast / medium / slow
# TRANSCODE_THREADS=0           # 0 = use all available CPU cores
# TRANSCODE_AUDIO_BITRATE=128k  # audio quality (e.g. 96k, 128k, 192k)

