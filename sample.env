# Copy this file to .env and edit as needed

# Port the app listens on (host port when bridge mode, uvicorn port when host mode)
# Set a unique APP_PORT per folder if you want to run multiple instances
APP_PORT=5705


# Timezone for log timestamps (default: UTC)
# Use a tz database name: America/New_York, America/Chicago, America/Los_Angeles, Europe/London, etc.
# TZ=America/New_York

# Log verbosity (default: INFO)
# INFO  — normal operation: startup, stream start/end, M3U fetches, VPN/MQTT connect
# DEBUG — everything: per-request timing, channel loading, EPG matching, stream reconnect details
# WARNING — only problems and errors
# LOG_LEVEL=INFO

# Docker container name (default: streamer1)
# Change this when running multiple instances to avoid name conflicts.
CONTAINER_NAME=streamer1

POLL_INTERVAL=30                 # seconds between model live-status checks
MAX_CONCURRENT=3                 # max simultaneous browser/recording sessions

